    {
      "id": "c2e3e27c-0e7f-46b2-9f43-d6a7cf20f8c7",
      "type": "paragraph",
      "text": "Students in a course were provided with an opt-in option to receive personalized notifications about how they will do in a course and some personalized recommended resources. In addition, struggling students received code solutions from high performing students.",
      "raw": {
        "object": "block",
        "id": "c2e3e27c-0e7f-46b2-9f43-d6a7cf20f8c7",
        "parent": {
