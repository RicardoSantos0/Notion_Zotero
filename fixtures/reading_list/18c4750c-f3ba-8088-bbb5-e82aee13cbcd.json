    {
      "id": "1914750c-f3ba-80fc-a2e6-e95e57ac05dd",
      "type": "paragraph",
      "text": "Authors explore T-LSTM in 2 domains. First, self-paced learning, wherein authors compare T-LSTM vs other standard classifiers to predict success. On a second-approach, they follow an instructor-paced setting and try to predict learning gains. ",
      "raw": {
        "object": "block",
        "id": "1914750c-f3ba-80fc-a2e6-e95e57ac05dd",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-8088-bbb5-e82aee13cbcd"
        },
        "created_time": "2025-02-05T19:15:00.000Z",
        "last_edited_time": "2025-02-05T19:16:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
