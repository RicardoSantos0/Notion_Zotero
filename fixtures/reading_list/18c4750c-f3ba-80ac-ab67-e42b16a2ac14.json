    {
      "id": "18e4750c-f3ba-807d-b595-f8676f6c66fd",
      "type": "paragraph",
      "text": "Authors hypothesize that there is a relationship between student affect, engagement and their learning outcomes. Authors look into ASSISTments data and found boredom during exercises to be negatively correlated with performance. However, boredom during a tutoring session was positively correlated with performance. ",
      "raw": {
        "object": "block",
        "id": "18e4750c-f3ba-807d-b595-f8676f6c66fd",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-80ac-ab67-e42b16a2ac14"
        },
        "created_time": "2025-02-02T20:05:00.000Z",
        "last_edited_time": "2025-02-02T20:10:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
