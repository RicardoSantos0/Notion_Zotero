    {
      "id": "8418d674-f21f-4b7a-b4a1-aea5848ba4af",
      "type": "paragraph",
      "text": "The authors use an Hidden Markov Model to mine sequential behaviors and create an EWS. Authors use OULAD as validation and achieve 90%´accuracy and AUC. In addition the authors also find that the optimal moment for early prediction is either the first or second quarter of a course.",
      "raw": {
        "object": "block",
        "id": "8418d674-f21f-4b7a-b4a1-aea5848ba4af",
        "parent": {
          "type": "page_id",
          "page_id": "c1065dd1-6f9b-4c60-ab59-d6ada7ca4e54"
        },
        "created_time": "2024-08-04T15:16:00.000Z",
