    {
      "id": "1b44750c-f3ba-8039-997b-ed7859d886c9",
      "type": "paragraph",
      "text": "Authors test effectiveness of recommender systems in educational platforms, bringing forward the example of music platforms - TomPlay - which suffer from the problem of having sparser interactions than other recommender system scenarios. ",
      "raw": {
        "object": "block",
        "id": "1b44750c-f3ba-8039-997b-ed7859d886c9",
        "parent": {
          "type": "page_id",
          "page_id": "d096f16e-0812-41fd-94af-511aec2df0a9"
        },
        "created_time": "2025-03-12T21:16:00.000Z",
        "last_edited_time": "2025-03-12T21:21:00.000Z",
