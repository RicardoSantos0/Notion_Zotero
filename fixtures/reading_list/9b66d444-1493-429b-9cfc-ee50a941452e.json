    {
      "id": "e3fd2045-c753-4672-9849-4ef8ac1a35ce",
      "type": "paragraph",
      "text": "Video lectures are a pivotal component of MOOC and a source of interesting data for analytical purposes. ",
      "raw": {
        "object": "block",
        "id": "e3fd2045-c753-4672-9849-4ef8ac1a35ce",
        "parent": {
