    {
      "id": "18f4750c-f3ba-809a-a17d-e3f7c646138c",
      "type": "paragraph",
      "text": "Learning analytics to perform early identification of students in need is underexplored in medicine. The study looks at online activites from mediical students and checks whether they correlate with performance.",
      "raw": {
        "object": "block",
        "id": "18f4750c-f3ba-809a-a17d-e3f7c646138c",
        "parent": {
          "type": "page_id",
