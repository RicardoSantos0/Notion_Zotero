    {
      "id": "1944750c-f3ba-808c-bb76-fcab5f35e87a",
      "type": "paragraph",
      "text": "Dropout prediction is a very popular learning analytics activity - after all, detecting students who are less likely to complete their programs is essential to prevent churn. The work uses data from first-year students attending a European University at two different moments of prediction: the beginning of the course or the end of the first semester.",
      "raw": {
        "object": "block",
        "id": "1944750c-f3ba-808c-bb76-fcab5f35e87a",
        "parent": {
          "type": "page_id",
          "page_id": "18d4750c-f3ba-808a-a0dc-d13b4b6556c4"
        },
        "created_time": "2025-02-08T22:56:00.000Z",
