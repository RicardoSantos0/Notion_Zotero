    {
      "id": "1b14750c-f3ba-8044-8c91-da7d79e00679",
      "type": "paragraph",
      "text": "The authors propose CoBERT, a fine-tuned BERT implemetation used in an item-based filtering Recommender System that is meant to provide employment recommendations to students and graduates. The model uses information that is demographic, relationship between employer and graduate and overall competency of the graduate in IT.",
      "raw": {
        "object": "block",
        "id": "1b14750c-f3ba-8044-8c91-da7d79e00679",
        "parent": {
          "type": "page_id",
          "page_id": "15232c7b-7d9a-4574-bb5f-9d11b60ac5fb"
        },
        "created_time": "2025-03-09T21:18:00.000Z",
        "last_edited_time": "2025-03-09T21:20:00.000Z",
        "created_by": {
