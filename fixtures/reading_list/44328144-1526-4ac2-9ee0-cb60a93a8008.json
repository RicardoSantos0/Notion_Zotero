    {
      "id": "aa1197db-c74f-4ee1-85d8-1e309ee438fa",
      "type": "paragraph",
      "text": "Paper examines relationship between student a risk usage of Elements of Success and their performance. Not only did the authors find that there was no relationship between knowing to be at risk and student withdrawal, the authors also found that students who checked the system actually were more likely to earn a passing grade relative to peers who never checked how they were doing.",
      "raw": {
        "object": "block",
        "id": "aa1197db-c74f-4ee1-85d8-1e309ee438fa",
        "parent": {
          "type": "page_id",
          "page_id": "44328144-1526-4ac2-9ee0-cb60a93a8008"
        },
        "created_time": "2024-08-01T22:12:00.000Z",
        "last_edited_time": "2024-08-01T22:15:00.000Z",
