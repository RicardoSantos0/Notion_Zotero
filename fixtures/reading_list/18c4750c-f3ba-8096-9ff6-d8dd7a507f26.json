    {
      "id": "1ae4750c-f3ba-8043-ad21-fe0b9d18c366",
      "type": "paragraph",
      "text": "Most of the KT work that exists is based on predicting whether a student will get a question right or wrong, often disregarding relevant indicators such as answering speed or number of attempts. Authors propose LBKT which is meant to explore these constructs. ",
      "raw": {
        "object": "block",
        "id": "1ae4750c-f3ba-8043-ad21-fe0b9d18c366",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-8096-9ff6-d8dd7a507f26"
        },
        "created_time": "2025-03-06T13:49:00.000Z",
        "last_edited_time": "2025-03-06T14:17:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
