  "tables": [
    {
      "block_id": "1dd4750c-f3ba-8080-a768-d172b977521c",
      "heading": "Abstract",
      "rows": [
        [
          "Task",
          "Context",
          "Student Performance Definition",
          "Target",
          "Students",
