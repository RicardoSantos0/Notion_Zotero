    {
      "id": "1ad4750c-f3ba-800a-b8b1-e63b5ed1e3b5",
      "type": "paragraph",
      "text": "Deep Knowledge Tracing has been able to achieve state-of-the-art performances in the representation of students’ knowledge states. One disadvantage of this technique is the lack of interpretability of the model (especially when compared against BKT). ",
      "raw": {
        "object": "block",
        "id": "1ad4750c-f3ba-800a-b8b1-e63b5ed1e3b5",
        "parent": {
          "type": "page_id",
          "page_id": "18b4750c-f3ba-80bf-8703-db27a50b8f28"
        },
        "created_time": "2025-03-05T18:00:00.000Z",
        "last_edited_time": "2025-03-05T18:01:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Deep Knowledge Tracing has been able to achieve state-of-the-art performances in the representation of students’ knowledge states. One disadvantage of this technique is the lack of interpretability of the model (especially when compared against BKT). ",
