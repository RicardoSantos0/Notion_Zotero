    {
      "id": "5ae135d8-5ac0-4b66-8350-ad368a46e849",
      "type": "paragraph",
      "text": "Work focuses on combining the trace data obtained from LMS logs and regularly used to predict performance with self-reported indicators often used to identify SRL. To do that, the authors perform a case-study on a sample of 145 students. Students perform a self-report assessment for SRL indicators and their logs are collected and analyzed.",
      "raw": {
        "object": "block",
        "id": "5ae135d8-5ac0-4b66-8350-ad368a46e849",
        "parent": {
          "type": "page_id",
          "page_id": "8bb53b06-6318-4286-b722-2dd1f69c0984"
        },
        "created_time": "2024-07-30T18:10:00.000Z",
        "last_edited_time": "2024-07-30T18:13:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
