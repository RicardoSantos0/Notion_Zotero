    {
      "id": "29dd2927-45af-4dfd-bb8d-2fcdc4a09a69",
      "type": "paragraph",
      "text": "Results show that a model that combines both sources of data leads to a greater explained variance of the final score than when the sources are used in isolation. Authors make no specific mention of early prediction in the abstract.",
      "raw": {
        "object": "block",
        "id": "29dd2927-45af-4dfd-bb8d-2fcdc4a09a69",
        "parent": {
