    {
      "id": "7615268e-7e54-487c-ad46-d5eaf83e1e40",
      "type": "paragraph",
      "text": "Online help-seeking is a complex phenomenom with many intricacies that ultimately have an effect on student performance. However, when studying the phenomenon, researchers often treat help-seeking as a factor to be isolated from remaining context. ",
      "raw": {
        "object": "block",
        "id": "7615268e-7e54-487c-ad46-d5eaf83e1e40",
        "parent": {
          "type": "page_id",
