    {
      "id": "12a4750c-f3ba-80cd-9f15-de82052795e8",
      "type": "paragraph",
      "text": "The purpose of the work is to use logs to do early prediction on the final exam at an institution-wide level. The reason for this approach is the small sample size of the individual courses, even considering that the data includes 5 years. The initial sample considers 255659 exam sittings. ",
      "raw": {
        "object": "block",
        "id": "12a4750c-f3ba-80cd-9f15-de82052795e8",
        "parent": {
          "type": "page_id",
          "page_id": "42ad0b30-debb-4504-bffa-b7c7db7f2759"
        },
        "created_time": "2024-10-25T17:55:00.000Z",
        "last_edited_time": "2024-10-25T18:26:00.000Z",
