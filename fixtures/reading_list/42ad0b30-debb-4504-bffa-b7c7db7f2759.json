    {
      "id": "12a4750c-f3ba-8024-b8d2-da91f15940e6",
      "type": "paragraph",
      "text": "The work is inspired by Course Signals, a system that identifies students in need and then informs faculty to help students. The advantage of using an architecture that works with sequences is that it does not require extraction of meta-features from the logs. ",
      "raw": {
        "object": "block",
        "id": "12a4750c-f3ba-8024-b8d2-da91f15940e6",
        "parent": {
