    {
      "id": "3a800cca-8c31-427d-9d10-390e8141a2e3",
      "type": "paragraph",
      "text": "Predictive models for early identification of struggling students often overlook the reason for why a model may perform or not. To identify possible factors that influence model performance, the authors used 7 datasets from 3 institutions.",
      "raw": {
        "object": "block",
        "id": "3a800cca-8c31-427d-9d10-390e8141a2e3",
        "parent": {
          "type": "page_id",
          "page_id": "d0387c40-4fcf-4d80-bea3-7ebd188eec48"
        },
        "created_time": "2024-08-01T11:26:00.000Z",
        "last_edited_time": "2024-08-01T11:29:00.000Z",
        "created_by": {
          "object": "user",
