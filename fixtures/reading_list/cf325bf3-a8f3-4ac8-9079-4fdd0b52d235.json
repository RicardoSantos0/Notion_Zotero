    {
      "id": "1d1280de-950e-4cc1-8e78-d81719e7a2ed",
      "type": "paragraph",
      "text": "Authors start by identifying that most works of Dropout prediction suffer from data leakage - Performance of predictive models is measured on the same dataset used for training. To test the effects, authors create a model using 4 different training paradigms. ",
      "raw": {
        "object": "block",
        "id": "1d1280de-950e-4cc1-8e78-d81719e7a2ed",
