    {
      "id": "bc50cd69-551f-4a3b-97a2-802824d8ac27",
      "type": "paragraph",
      "text": "This work focuses on benchmarking deep learning frameworks on 2 distinct educational datasets. The authors find that the Optimizer and the hyper-parameters used in different models do, in fact, reveal differences in Model Performance. More surprisingly though, the authors found that the model performances obtained using Deep Learning packages is comparable to other traditional methos. ",
      "raw": {
        "object": "block",
        "id": "bc50cd69-551f-4a3b-97a2-802824d8ac27",
        "parent": {
          "type": "page_id",
          "page_id": "caf06b29-9fe4-4e98-b1ab-83d613b41d1e"
        },
        "created_time": "2024-08-01T11:55:00.000Z",
        "last_edited_time": "2024-08-01T11:57:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "This work focuses on benchmarking deep learning frameworks on 2 distinct educational datasets. The authors find that the Optimizer and the hyper-parameters used in different models do, in fact, reveal differences in Model Performance. More surprisingly though, the authors found that the model performances obtained using Deep Learning packages is comparable to other traditional methos. ",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
