    {
      "id": "1ae4750c-f3ba-8010-8fb0-d8fa28622667",
      "type": "paragraph",
      "text": "The work explores 3 algorithms that may be used to form groups for computer-supported collaborative learning in ITS aimed at K-12 students. The algorithms use multidimensional views of student ability comprising multiple hundred attributes.",
      "raw": {
        "object": "block",
        "id": "1ae4750c-f3ba-8010-8fb0-d8fa28622667",
        "parent": {
          "type": "page_id",
          "page_id": "30995e29-4aac-403a-9399-9d6273238e6f"
        },
        "created_time": "2025-03-06T17:28:00.000Z",
        "last_edited_time": "2025-03-06T17:30:00.000Z",
        "created_by": {
