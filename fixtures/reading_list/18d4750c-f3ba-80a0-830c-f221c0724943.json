    {
      "id": "1924750c-f3ba-8027-aa20-ee3ca6ba953b",
      "type": "paragraph",
      "text": "The work uses multiple ML models on 2 Chilean universities with the goal of predicting the probability of first-year engineering students dropping out. Reulsts show that doing university-specific models would lead to better results, with Gradfient-Boosting approaches being among the top-performing. ",
      "raw": {
        "object": "block",
        "id": "1924750c-f3ba-8027-aa20-ee3ca6ba953b",
        "parent": {
          "type": "page_id",
          "page_id": "18d4750c-f3ba-80a0-830c-f221c0724943"
        },
        "created_time": "2025-02-06T14:52:00.000Z",
        "last_edited_time": "2025-02-06T15:03:00.000Z",
