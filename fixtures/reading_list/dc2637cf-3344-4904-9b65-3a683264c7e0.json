    {
      "id": "44e28ff8-11bd-4d87-864f-9dd25ada25b8",
      "type": "paragraph",
      "text": "Authors propose an early warning system that identifies academic success to first-year higher education students. Dataset includes close to 12000 students and 69 features that predict academic success at the end of the first year.  Authors use NB, RF and DT, with RF reaching 90% accuracy. ",
      "raw": {
        "object": "block",
        "id": "44e28ff8-11bd-4d87-864f-9dd25ada25b8",
        "parent": {
          "type": "page_id",
          "page_id": "dc2637cf-3344-4904-9b65-3a683264c7e0"
        },
        "created_time": "2024-07-22T17:37:00.000Z",
        "last_edited_time": "2024-07-22T17:40:00.000Z",
