    {
      "id": "1914750c-f3ba-80b7-b9cc-c87e2417c8f3",
      "type": "paragraph",
      "text": "Paper proposes 2 approaches of recommender systems aimed at recommending resources that maximize score while taking into account the user’s time constraints. The approach is based on a two-layered course graph (lesson and LO).",
      "raw": {
        "object": "block",
        "id": "1914750c-f3ba-80b7-b9cc-c87e2417c8f3",
        "parent": {
          "type": "page_id",
          "page_id": "e9713e42-06ca-414a-b5e8-a023387fd923"
        },
        "created_time": "2025-02-05T23:34:00.000Z",
        "last_edited_time": "2025-02-05T23:40:00.000Z",
        "created_by": {
