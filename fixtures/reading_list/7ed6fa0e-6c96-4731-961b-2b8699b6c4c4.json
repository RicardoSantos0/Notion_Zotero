    {
      "id": "1ab4750c-f3ba-800c-80e6-ccc81f2af368",
      "type": "paragraph",
      "text": "Authors argues for the need of a job recommender system for fresh college graduates. The current system is flawed in the sense that in only considers the one-way student desires, often not taking into account ever-changing differences in student behavior. ",
      "raw": {
        "object": "block",
        "id": "1ab4750c-f3ba-800c-80e6-ccc81f2af368",
        "parent": {
          "type": "page_id",
          "page_id": "7ed6fa0e-6c96-4731-961b-2b8699b6c4c4"
        },
        "created_time": "2025-03-03T23:37:00.000Z",
        "last_edited_time": "2025-03-03T23:41:00.000Z",
