    {
      "id": "3f0a1d58-faae-435e-a11d-7f2ab879e024",
      "type": "paragraph",
      "text": "The validity of assessments heavily relies on alignment between the assessment and the intended Learning Outcomes. The aim of the paper is to identify what is the predictive power of formative assessment for summative assessment (and consequently acquisition of LOs).",
      "raw": {
        "object": "block",
        "id": "3f0a1d58-faae-435e-a11d-7f2ab879e024",
        "parent": {
          "type": "page_id",
          "page_id": "88c914bd-0f71-409e-8ec4-5ede58830c02"
        },
        "created_time": "2024-08-06T21:02:00.000Z",
        "last_edited_time": "2024-08-06T21:04:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "The validity of assessments heavily relies on alignment between the assessment and the intended Learning Outcomes. The aim of the paper is to identify what is the predictive power of formative assessment for summative assessment (and consequently acquisition of LOs).",
                "link": null
