    {
      "id": "589d1d22-5fb4-4249-8ae8-1facaafca181",
      "type": "paragraph",
      "text": "Authors look at formative assessment results and log data and use them as inputs for a RF model. REsults on data from 2 math courses shows that formative assessments, combined with previous summative assessments are good predictors of summative assessment and, moreover, better predictors than any form of student engagement. ",
      "raw": {
        "object": "block",
        "id": "589d1d22-5fb4-4249-8ae8-1facaafca181",
        "parent": {
          "type": "page_id",
          "page_id": "88c914bd-0f71-409e-8ec4-5ede58830c02"
        },
        "created_time": "2024-08-06T21:04:00.000Z",
        "last_edited_time": "2024-08-06T21:06:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
