  "tables": [
    {
      "block_id": "1ce4750c-f3ba-802d-9ebc-eeb1df69d0a0",
      "heading": "Summary Table KT",
      "rows": [
        [
          "Task",
          "Context",
          "Student Performance Definition",
          "Target",
          "Students",
          "Courses",
          "Data sources",
          "Features",
          "Flaw of Previous Models",
