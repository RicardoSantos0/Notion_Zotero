    {
      "id": "5331dc91-e331-4f0e-9842-8fcc57badfd5",
      "type": "paragraph",
      "text": "Transfer Learning refers to the process of taking a model trained in one context and applying it to another. Authors attempt to perform transfer learning on educational data and thus obtain data from 5 compulsory courses of two undergraduate programs.",
      "raw": {
        "object": "block",
        "id": "5331dc91-e331-4f0e-9842-8fcc57badfd5",
        "parent": {
          "type": "page_id",
          "page_id": "e33616be-ee22-468f-ad4c-2d3747da47c9"
        },
        "created_time": "2024-08-01T11:38:00.000Z",
        "last_edited_time": "2024-08-01T11:41:00.000Z",
