    {
      "id": "1ab4750c-f3ba-80af-99e6-e4becbe182fb",
      "type": "paragraph",
      "text": "Education in the 21st century needs to rapidly adapt to everchanging demands from the job market. Data, as always, can help due to its unprecedented availability. Authors propose eDoer, a new educational recommender system that is labor market oriented. ",
      "raw": {
        "object": "block",
        "id": "1ab4750c-f3ba-80af-99e6-e4becbe182fb",
        "parent": {
          "type": "page_id",
