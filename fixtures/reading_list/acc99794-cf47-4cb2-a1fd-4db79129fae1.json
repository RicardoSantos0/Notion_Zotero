    {
      "id": "cd4c0740-5d37-4a12-a38f-35678b901aec",
      "type": "paragraph",
      "text": "The work uses video clickstream records on a MOOC to identify 7 types of cognitive participation models. This feature extraction is followed by the creation of a predictive model that predicts student performance, with ANN taking the take as the one achieving the highest accuracy. ",
      "raw": {
        "object": "block",
        "id": "cd4c0740-5d37-4a12-a38f-35678b901aec",
