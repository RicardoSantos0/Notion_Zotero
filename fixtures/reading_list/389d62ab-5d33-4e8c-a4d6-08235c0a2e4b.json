    {
      "id": "a398713d-7583-4a49-b3f9-0a5186c907e2",
      "type": "paragraph",
      "text": "Authors use 2 wrapper-methods for Semi-Supervised Learning to predict performance of High-School students in their final examinations. Authors argue that the SSL approach significantly increases prediction accuracy, thus leading to more reliable predictive models. ",
      "raw": {
        "object": "block",
        "id": "a398713d-7583-4a49-b3f9-0a5186c907e2",
