    {
      "id": "1ad4750c-f3ba-8086-9eb2-c51fe2d56463",
      "type": "paragraph",
      "text": "Dropout prediction is a common Learning Analytics task and, in may scenarios, institutions have models put into place to predict it, raising questions on whether sensitive attributes should be used or not. ",
      "raw": {
        "object": "block",
        "id": "1ad4750c-f3ba-8086-9eb2-c51fe2d56463",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-8093-856f-efcb99126d44"
        },
        "created_time": "2025-03-05T15:15:00.000Z",
        "last_edited_time": "2025-03-05T15:17:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
