    {
      "id": "fe4cb802-ea88-4d01-9657-2cd6299357a3",
      "type": "paragraph",
      "text": "Authors of the paper use a sample of close to 5000 students and collect logs, survey answers and course achievement variables from them. The analysis of this data shows that Goal Setting and Strategic Planning are the most effective SRL skills to have to be successful while struggling students who seek help often underperform their peers.",
      "raw": {
        "object": "block",
        "id": "fe4cb802-ea88-4d01-9657-2cd6299357a3",
        "parent": {
          "type": "page_id",
          "page_id": "b1429cd5-75c5-4854-a368-a0d01a6f7cac"
        },
        "created_time": "2024-07-30T18:30:00.000Z",
        "last_edited_time": "2024-07-30T18:31:00.000Z",
