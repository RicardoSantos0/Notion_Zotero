    {
      "id": "adb1ec91-a2bf-4279-b4d1-138502ae9a6a",
      "type": "paragraph",
      "text": "Success in MOOCs requires good SRL skills. However, not all students have these skills developed. Thus it is important not only to be able to identify which SRL strategies should be promoted BUT to also identify which SRL are underdeveloped in the student population.",
      "raw": {
        "object": "block",
        "id": "adb1ec91-a2bf-4279-b4d1-138502ae9a6a",
        "parent": {
          "type": "page_id",
          "page_id": "b1429cd5-75c5-4854-a368-a0d01a6f7cac"
        },
        "created_time": "2024-07-30T18:25:00.000Z",
        "last_edited_time": "2024-07-30T18:30:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
