    {
      "id": "96b1e7ae-be9d-4482-9984-7a879ec24168",
      "type": "paragraph",
      "text": "Authors find that body temperature, skin conductance and heart rate could be used to predict whether a student is in a problem-solving activity, leisure or daydreaming. ",
      "raw": {
        "object": "block",
        "id": "96b1e7ae-be9d-4482-9984-7a879ec24168",
        "parent": {
          "type": "page_id",
