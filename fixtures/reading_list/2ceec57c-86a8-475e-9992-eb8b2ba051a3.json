    {
      "id": "1b34750c-f3ba-8046-afd7-eb21400dee10",
      "type": "paragraph",
      "text": "Recommender systems offer the promise of generating personalized learning pathways in distance learning. The authors propose an approach that computes scores for topics and asks users to score different topics according to their interest and uses these scores to recommend personalized learning pathways.",
      "raw": {
        "object": "block",
        "id": "1b34750c-f3ba-8046-afd7-eb21400dee10",
        "parent": {
          "type": "page_id",
