    {
      "id": "b7f566a3-d194-4093-9292-eb88c852f3d4",
      "type": "paragraph",
      "text": "Authors propose a novel answer forectasting model called QStudentBert. This model integrates LLMs to understand student context and answer history. The idea is to create embeddings of student context and previous answers and use them as the inputs for a fine-tuned BERT. ",
      "raw": {
        "object": "block",
        "id": "b7f566a3-d194-4093-9292-eb88c852f3d4",
        "parent": {
