    {
      "id": "2967afcd-40cd-43a1-861e-f3b3bba60bca",
      "type": "paragraph",
      "text": "Authors propose a new Attention based Multi Layer LSTM model in the hopes of improving predictive accuracy as soon as possible. On the dataset used (undisclosed), authors were able to obtain improvements in performance across different metrics between Weeks 5 to 25.",
