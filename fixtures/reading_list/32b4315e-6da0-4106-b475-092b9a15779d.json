        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "The results show that combining both feature extraction methods outperforms the use of exclusive manual expert feature engineering. Authors follow-up with an analysis of feature importance even though, at this stage, they make no explicit mention on what were the moist important features. ",
                "link": null
              },
