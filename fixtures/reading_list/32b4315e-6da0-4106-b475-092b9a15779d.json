    {
      "id": "e0f5843d-eaa4-4b89-a0a4-33b9715ff7b2",
      "type": "paragraph",
      "text": "The results show that combining both feature extraction methods outperforms the use of exclusive manual expert feature engineering. Authors follow-up with an analysis of feature importance even though, at this stage, they make no explicit mention on what were the moist important features. ",
      "raw": {
        "object": "block",
        "id": "e0f5843d-eaa4-4b89-a0a4-33b9715ff7b2",
        "parent": {
          "type": "page_id",
