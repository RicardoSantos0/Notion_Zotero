    {
      "id": "1b44750c-f3ba-80cb-b901-e8ce68717feb",
      "type": "paragraph",
      "text": "The current KT approaches either model knowledge for different concepts separately or fail at capturing longer-term dependencies in an historical sequence of questions. To address this issue, the authors propose Bayesian Cognitive-Aware Key-Value Memory Networks, a model that combines multiple popular KT architectures (DKVMN, LSTM and Bayesian theory). ",
      "raw": {
        "object": "block",
        "id": "1b44750c-f3ba-80cb-b901-e8ce68717feb",
        "parent": {
          "type": "page_id",
          "page_id": "18b4750c-f3ba-80ee-be85-c86f9e7d8bbf"
        },
        "created_time": "2025-03-12T17:34:00.000Z",
        "last_edited_time": "2025-03-12T17:38:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "The current KT approaches either model knowledge for different concepts separately or fail at capturing longer-term dependencies in an historical sequence of questions. To address this issue, the authors propose Bayesian Cognitive-Aware Key-Value Memory Networks, a model that combines multiple popular KT architectures (DKVMN, LSTM and Bayesian theory). ",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
