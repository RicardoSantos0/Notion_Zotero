    {
      "id": "1b44750c-f3ba-8022-a768-e3430e7aa1b1",
      "type": "paragraph",
      "text": "Paper introduces a new approach using multi-criteria integer programming for team formation. The model considers multiple factors including skill level, background and personality traits. Algorithm focuses on maximizing whithin-group differences while minizing between-group differences. ",
      "raw": {
        "object": "block",
        "id": "1b44750c-f3ba-8022-a768-e3430e7aa1b1",
        "parent": {
          "type": "page_id",
