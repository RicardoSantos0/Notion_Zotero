    {
      "id": "1914750c-f3ba-8081-a785-c1dcfe4419b1",
      "type": "paragraph",
      "text": "Collaborative learning benefits from clustering students into appropriate learner groups. However, most group optimization is performed via single-objective optimization, not accounting for multiple constraints. To address this, authors propose a multi-objective Genetic algorithm, NSGA-II. ",
      "raw": {
        "object": "block",
        "id": "1914750c-f3ba-8081-a785-c1dcfe4419b1",
        "parent": {
          "type": "page_id",
          "page_id": "68e843ee-ef18-4592-a389-4a318e4fd94a"
        },
        "created_time": "2025-02-05T00:32:00.000Z",
        "last_edited_time": "2025-02-05T00:34:00.000Z",
