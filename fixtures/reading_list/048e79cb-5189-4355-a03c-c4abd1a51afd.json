    {
      "block_id": "2414750c-f3ba-80cf-a75e-e56d97e30044",
      "heading": "Abstract",
      "rows": [
        [
          "Context",
          "Teaching Method",
          "Recommender System Type",
          "Target of Recommendation",
          "Students",
          "Courses",
