    {
      "id": "1ac4750c-f3ba-8016-a8b0-ecef236514cf",
      "type": "paragraph",
      "text": "Students in Sofware Engineering Capstone Courses are usually recommended to record their learnings. However, students of future iterations usually are unable to take full advantage of these recordings. ",
      "raw": {
        "object": "block",
        "id": "1ac4750c-f3ba-8016-a8b0-ecef236514cf",
        "parent": {
