      "block_id": "1ce4750c-f3ba-8070-938f-ff66113cd584",
      "heading": "Abstract",
      "rows": [
        [
          "Task",
          "Context",
          "Student Performance Definition",
          "Target",
          "Students",
          "Courses",
          "Data sources",
          "Features",
          "Flaw of Previous Models",
          "Novelty of Model",
          "Preprocessing Details",
