    {
      "id": "1924750c-f3ba-8052-8077-df3795104d82",
      "type": "paragraph",
      "text": "MOOCs have plenty of flexibility when it comes to the learning paths they wish to pursue. This great flexibility gives plenty of options to students and current course recommenders tend to rely on previous courses to suggest good next steps. However, these recommenders do not account for student knowledge.",
      "raw": {
        "object": "block",
        "id": "1924750c-f3ba-8052-8077-df3795104d82",
        "parent": {
          "type": "page_id",
          "page_id": "d0797811-8d5a-4f9d-985b-e5180265316e"
        },
        "created_time": "2025-02-06T23:40:00.000Z",
        "last_edited_time": "2025-02-06T23:43:00.000Z",
