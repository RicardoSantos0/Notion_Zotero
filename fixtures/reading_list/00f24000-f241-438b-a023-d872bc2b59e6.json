    {
      "id": "6a5b6974-fefb-4079-92ee-8ff78e579b4b",
      "type": "paragraph",
      "text": "Authors find 4 groups: Early planning, Planning, Procrastination and Low Engagement and see that planning behavior is essencial towards success in the course.  ",
      "raw": {
        "object": "block",
        "id": "6a5b6974-fefb-4079-92ee-8ff78e579b4b",
        "parent": {
          "type": "page_id",
