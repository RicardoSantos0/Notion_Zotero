    {
      "id": "466b731f-e00e-4743-bdfd-a00fbe92f5eb",
      "type": "paragraph",
      "text": "The literature features a lack of course-agnostic models and mostly focuses on models that aim to achieve the best predictive performance in a single course. Thus, the aim of the paper is to study portability of models across multiple courses.",
      "raw": {
        "object": "block",
        "id": "466b731f-e00e-4743-bdfd-a00fbe92f5eb",
        "parent": {
          "type": "page_id",
          "page_id": "ee02d517-31b2-462f-9792-de63e51be12b"
        },
        "created_time": "2024-08-01T11:33:00.000Z",
        "last_edited_time": "2024-08-01T11:34:00.000Z",
        "created_by": {
