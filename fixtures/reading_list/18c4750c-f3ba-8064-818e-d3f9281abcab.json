    {
      "id": "1914750c-f3ba-8049-bf63-f6039329d314",
      "type": "paragraph",
      "text": "Deep learning models in KT seem to be the state-of-the-art but seem to underestimate the contribution of the most recent answers for the current knowledge state, which is counterintuitive. To address this, the authors propose a Convolutional KT model, that uses 3D convolutions. ",
      "raw": {
        "object": "block",
        "id": "1914750c-f3ba-8049-bf63-f6039329d314",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-8064-818e-d3f9281abcab"
        },
        "created_time": "2025-02-05T22:09:00.000Z",
        "last_edited_time": "2025-02-05T22:10:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Deep learning models in KT seem to be the state-of-the-art but seem to underestimate the contribution of the most recent answers for the current knowledge state, which is counterintuitive. To address this, the authors propose a Convolutional KT model, that uses 3D convolutions. ",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
