    {
      "id": "1914750c-f3ba-80b9-a106-cbf069fa0053",
      "type": "paragraph",
      "text": "KT looks at past responses from students and uses them to create a model of the students’ knowledge. This model can later be used to predict the probability of getting a new question right. Good KT models can help students identify where a student is lacking in terms of knowledge, which can also be used by professors to better prepare new materials. ",
      "raw": {
        "object": "block",
        "id": "1914750c-f3ba-80b9-a106-cbf069fa0053",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-8064-818e-d3f9281abcab"
        },
        "created_time": "2025-02-05T22:06:00.000Z",
        "last_edited_time": "2025-02-05T22:08:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
