    {
      "id": "1924750c-f3ba-8010-b080-cecf6a88c64f",
      "type": "paragraph",
      "text": "Non-assessed learning resources are often ignored in KT even though they generally contain multiple materials that are necessary for students to acquire knowledge. The paper introduces Deep Multi Knowledge Tracing (DMKT) that models transitions between assess and non-assessed learning activities. ",
      "raw": {
        "object": "block",
        "id": "1924750c-f3ba-8010-b080-cecf6a88c64f",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-8062-842c-e18fda26dfd7"
        },
        "created_time": "2025-02-06T16:16:00.000Z",
        "last_edited_time": "2025-02-06T16:20:00.000Z",
