    {
      "id": "1b34750c-f3ba-8083-adc1-c2d38b22eeec",
      "type": "paragraph",
      "text": "Creating a representation of a learner’s knowledge state is important (more than just on KT) in the design of educational recommender systems. However, current recommenders have problems with transparency in the learner model and how it relates with the learning materials. The paper proposes an approach using Personal Knowledge Graphs. ",
      "raw": {
        "object": "block",
        "id": "1b34750c-f3ba-8083-adc1-c2d38b22eeec",
        "parent": {
          "type": "page_id",
          "page_id": "756c4ee6-edde-4892-9c91-9303c10302a2"
        },
        "created_time": "2025-03-11T17:47:00.000Z",
        "last_edited_time": "2025-03-11T17:52:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
