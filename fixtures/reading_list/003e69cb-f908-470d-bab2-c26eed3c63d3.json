  "tables": [
    {
      "block_id": "29c4750c-f3ba-80d0-84dd-eb9ea2cf5042",
      "heading": "Summary Table REC",
      "rows": [
        [
          "Context",
          "Teaching Method",
          "Recommender System Type",
          "Target of Recommendation",
          "Students",
          "Courses",
