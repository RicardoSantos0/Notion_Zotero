    {
      "id": "1b64750c-f3ba-8050-87d4-e7957e3d652b",
      "type": "numbered_list_item",
      "text": "Focus on recommending exercises not yet mastered, which leaves little space for learners to practice fundamentals or the learner’s long-term needs.",
