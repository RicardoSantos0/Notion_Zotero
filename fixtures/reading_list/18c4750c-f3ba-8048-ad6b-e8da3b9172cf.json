    {
      "id": "1ad4750c-f3ba-808a-9095-cdfdae0c15e6",
      "type": "paragraph",
      "text": "Most of the literature on early warning systems for students at risk does not use probabilistic approaches. To fill this gap, the authors use a five-stage Logistic Regression model trained on Moodle logs, demographic information and student assessment data to predict the probability of a student failing an upcoming assessment.",
      "raw": {
        "object": "block",
        "id": "1ad4750c-f3ba-808a-9095-cdfdae0c15e6",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-8048-ad6b-e8da3b9172cf"
        },
        "created_time": "2025-03-05T16:55:00.000Z",
        "last_edited_time": "2025-03-05T16:58:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Most of the literature on early warning systems for students at risk does not use probabilistic approaches. To fill this gap, the authors use a five-stage Logistic Regression model trained on Moodle logs, demographic information and student assessment data to predict the probability of a student failing an upcoming assessment.",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
                "underline": false,
                "code": false,
                "color": "default"
              },
              "plain_text": "Most of the literature on early warning systems for students at risk does not use probabilistic approaches. To fill this gap, the authors use a five-stage Logistic Regression model trained on Moodle logs, demographic information and student assessment data to predict the probability of a student failing an upcoming assessment.",
              "href": null
            }
          ],
          "icon": null,
