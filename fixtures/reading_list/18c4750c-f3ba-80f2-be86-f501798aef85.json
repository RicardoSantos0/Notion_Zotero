    {
      "id": "1944750c-f3ba-8043-a3bc-de4c083dc58c",
      "type": "paragraph",
      "text": "Authors propose Complexity-based Attentive Interactive Student Performance (CAISP). The model uses attention networks. When tested on 2 real-word, datasets, CAISP outperformed two state-of-the-art solutions.",
      "raw": {
        "object": "block",
        "id": "1944750c-f3ba-8043-a3bc-de4c083dc58c",
