    {
      "id": "1944750c-f3ba-802f-87c6-ef412d8ac746",
      "type": "paragraph",
      "text": "Student performance prediction is used to leverage existing information about students to predict future learning performance. Authors follow a predictive approach to predict course grades. Most studies look into different aspects of learning but fail to account for how different factors (features) affect different learners.",
      "raw": {
        "object": "block",
        "id": "1944750c-f3ba-802f-87c6-ef412d8ac746",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-80f2-be86-f501798aef85"
        },
        "created_time": "2025-02-08T22:46:00.000Z",
        "last_edited_time": "2025-02-08T22:54:00.000Z",
