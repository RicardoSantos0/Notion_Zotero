    {
      "id": "2e8d5080-2f64-421c-8655-449a13beda43",
      "type": "paragraph",
      "text": "This work looks at SRL behaviors while using an educational technology. The authors reviewed the learning behaviors of their students and how that translated into student performance. The results show that students who progressed more tended to spend more time reviewing their mistakes and were dilligent in their process throughout the semester.",
      "raw": {
        "object": "block",
        "id": "2e8d5080-2f64-421c-8655-449a13beda43",
        "parent": {
          "type": "page_id",
          "page_id": "6e24a628-cecf-44d7-87a6-7a24c6616397"
        },
        "created_time": "2024-07-31T17:42:00.000Z",
        "last_edited_time": "2024-07-31T17:45:00.000Z",
        "created_by": {
          "object": "user",
