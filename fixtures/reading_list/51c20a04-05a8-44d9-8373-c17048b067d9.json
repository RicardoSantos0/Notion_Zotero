    {
      "id": "1b34750c-f3ba-807a-9ee8-e9a405d8f0b8",
      "type": "paragraph",
      "text": "Heterogenous Information network embedding-based Recommendations face challenges related with the heterogenous nature of the way users or items are represented. The authors propose a new form of recommendations SEMH4Rec that is meant to create better representations of users and items and feeds them to a Matrix Factorization algorithm.",
      "raw": {
        "object": "block",
        "id": "1b34750c-f3ba-807a-9ee8-e9a405d8f0b8",
        "parent": {
          "type": "page_id",
          "page_id": "51c20a04-05a8-44d9-8373-c17048b067d9"
        },
        "created_time": "2025-03-11T17:15:00.000Z",
        "last_edited_time": "2025-03-11T17:23:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
