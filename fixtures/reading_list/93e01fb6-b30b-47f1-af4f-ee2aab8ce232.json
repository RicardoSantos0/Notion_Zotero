    {
      "id": "1ab4750c-f3ba-80c0-8554-fce74d1ea23d",
      "type": "paragraph",
      "text": "In K-12 tests are often done in pre-determined dates without taking into consideration the pace at which different students may actually learn. The authors propose a recommender system that finds the optimal time when a student should be tested. Authors test the effectiveness of their system in a large dataset of Second and Fourth-graders. ",
      "raw": {
        "object": "block",
        "id": "1ab4750c-f3ba-80c0-8554-fce74d1ea23d",
        "parent": {
          "type": "page_id",
          "page_id": "93e01fb6-b30b-47f1-af4f-ee2aab8ce232"
        },
        "created_time": "2025-03-03T23:04:00.000Z",
        "last_edited_time": "2025-03-03T23:07:00.000Z",
