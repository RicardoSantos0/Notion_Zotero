    {
      "id": "d7f524f5-f73d-4200-bc25-3a7cea539057",
      "type": "paragraph",
      "text": "For the predictive modeling part, the system uses historical data, demographics, logged interactions and progress in Labs to predict end of course achievement every week. By the second part of the semester, students were given an opt-in option to receive how well they are expected to do in the course AND recommendations to tackle their difficulties. ",
      "raw": {
        "object": "block",
        "id": "d7f524f5-f73d-4200-bc25-3a7cea539057",
        "parent": {
          "type": "page_id",
          "page_id": "189f2a61-52f2-477e-b2b4-eebe2934fb4c"
        },
        "created_time": "2024-07-31T17:53:00.000Z",
        "last_edited_time": "2024-07-31T17:55:00.000Z",
