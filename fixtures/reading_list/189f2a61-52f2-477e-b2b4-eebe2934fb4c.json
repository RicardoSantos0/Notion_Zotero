    {
      "id": "0d5117d9-cbc9-4e2e-80bf-444ede329a69",
      "type": "paragraph",
      "text": "The paper presents a platform called PredictCS that identifies struggling students AND makes personalized recommendations to them. The system contains a dashboard.",
      "raw": {
        "object": "block",
        "id": "0d5117d9-cbc9-4e2e-80bf-444ede329a69",
        "parent": {
          "type": "page_id",
