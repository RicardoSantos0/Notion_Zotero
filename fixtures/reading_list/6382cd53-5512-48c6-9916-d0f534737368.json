    {
      "id": "6e1368a1-2b00-4d0d-aaa6-989f2680a905",
      "type": "paragraph",
      "text": "It is important to identify students who will fail to graduate, so identifying students at risk in a course is of paramount importance. The authors propose a model that not only makes the prediction of students at-risk, but also that removes redundancies to reduce training time and support vectors. For that, the authors use RTV-SVM.",
      "raw": {
        "object": "block",
        "id": "6e1368a1-2b00-4d0d-aaa6-989f2680a905",
        "parent": {
          "type": "page_id",
          "page_id": "6382cd53-5512-48c6-9916-d0f534737368"
        },
        "created_time": "2024-08-01T14:21:00.000Z",
        "last_edited_time": "2024-08-01T14:27:00.000Z",
