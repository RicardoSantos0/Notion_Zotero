    {
      "id": "16d6fd39-2142-4741-8f64-fe2f69e786de",
      "type": "paragraph",
      "text": "Paper explores the introduction of eye-tracking to understand student learning behaviors and predict learning performance. Empyrical work that explores 110 children learning about bidy anatomy - the learning experience was extracted from eye-tracking, learner profiles, academic performances and time to complete an activity.",
      "raw": {
        "object": "block",
        "id": "16d6fd39-2142-4741-8f64-fe2f69e786de",
