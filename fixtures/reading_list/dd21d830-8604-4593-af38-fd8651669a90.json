    {
      "id": "1914750c-f3ba-8025-b068-d906f5898cb3",
      "type": "paragraph",
      "text": "Exercise recommendations can make or break learning. To be effective, an exercise needs to be challenging enough to foster interest while, simultaneously, being accessible. Collaborative Filtering is not effective at this since it recommends exercises based on past behavior of similar students. ",
      "raw": {
        "object": "block",
        "id": "1914750c-f3ba-8025-b068-d906f5898cb3",
        "parent": {
          "type": "page_id",
          "page_id": "dd21d830-8604-4593-af38-fd8651669a90"
        },
        "created_time": "2025-02-05T22:45:00.000Z",
        "last_edited_time": "2025-02-05T22:49:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
