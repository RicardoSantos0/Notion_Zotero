    {
      "id": "f9903641-8aa8-49e9-a02d-a124f01f12b1",
      "type": "paragraph",
      "text": "Authors propse an automated system for detection of at—risk students called RADAR. The authors do a pilot test of the system on a set of students from a school district.",
      "raw": {
        "object": "block",
        "id": "f9903641-8aa8-49e9-a02d-a124f01f12b1",
        "parent": {
          "type": "page_id",
