    {
      "id": "1904750c-f3ba-804a-b262-fc880961a5d3",
      "type": "paragraph",
      "text": "Knowledge Tracing estimates the performance of a student in different learning activities, allowing it to model the student’s mastery of different knowledge concepts. The current state-of-the-art methods are BKT, DKT and Dynamic Key-value Mmory Networks and all have the issue of poor generalization in the rpesence of sparse data.",
      "raw": {
        "object": "block",
        "id": "1904750c-f3ba-804a-b262-fc880961a5d3",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-800f-87b5-dbdbf1d32668"
        },
        "created_time": "2025-02-04T23:36:00.000Z",
        "last_edited_time": "2025-02-04T23:39:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
