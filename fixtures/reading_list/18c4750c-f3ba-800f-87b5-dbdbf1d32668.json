    {
      "id": "1904750c-f3ba-809d-bcba-eca1f0bb788e",
      "type": "paragraph",
      "text": "The authors propose an approach that estimates Knowledge Components from past activities (sort of using preceding knowledge components to estimate current ones?).  This approach is Self-Attention Based (SAKT). Results on multiple datasets show that SAKT beats other alternatives by an average 4.43% on the AUC score.",
      "raw": {
        "object": "block",
        "id": "1904750c-f3ba-809d-bcba-eca1f0bb788e",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-800f-87b5-dbdbf1d32668"
        },
        "created_time": "2025-02-04T23:40:00.000Z",
        "last_edited_time": "2025-02-04T23:42:00.000Z",
