    {
      "id": "0aa3fc36-7b4b-4f11-a9d5-293a62315306",
      "type": "paragraph",
      "text": "MOOCs have very high dropout rates. It is possible to use Analytics to create models that predict whether a student is likely to dropout or not. However, the models available do not have the finesse to enable personalized interventions. ",
      "raw": {
        "object": "block",
        "id": "0aa3fc36-7b4b-4f11-a9d5-293a62315306",
        "parent": {
          "type": "page_id",
          "page_id": "33b39b4f-6ebe-4803-8d8f-ac8a5578cc79"
        },
        "created_time": "2024-07-31T19:51:00.000Z",
        "last_edited_time": "2024-07-31T19:53:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
