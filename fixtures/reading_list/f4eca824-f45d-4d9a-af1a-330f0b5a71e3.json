    {
      "id": "1ad4750c-f3ba-80f5-9421-cb17ce790622",
      "type": "paragraph",
      "text": "The work proposes a recommender system that suggests peers and solutions to challenges based on reflections from students on the previous semesters. The recommendations are the suggestions of previous students. When testing it, the authors report that 70% of the recommended solutions were helpful.",
      "raw": {
        "object": "block",
        "id": "1ad4750c-f3ba-80f5-9421-cb17ce790622",
