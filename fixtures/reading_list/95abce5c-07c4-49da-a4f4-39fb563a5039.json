    {
      "id": "dc5abac7-b34c-48f9-a7eb-8c0350c9502f",
      "type": "paragraph",
      "text": "Problems with generalization of student models due to under representation of some student groups. Authors make use of federaed learning to create group specific models derived from a global student model. ",
      "raw": {
        "object": "block",
        "id": "dc5abac7-b34c-48f9-a7eb-8c0350c9502f",
        "parent": {
          "type": "page_id",
          "page_id": "95abce5c-07c4-49da-a4f4-39fb563a5039"
        },
        "created_time": "2024-08-04T11:42:00.000Z",
        "last_edited_time": "2024-08-04T11:52:00.000Z",
