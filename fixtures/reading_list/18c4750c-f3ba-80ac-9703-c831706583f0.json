              "type": "text",
              "text": {
                "content": "KT often revolves around using previous questions to predict whether the next question will be correctly answered. One of the main drawbacks of the traditional KT approaches is that it only considers correctedness of previous questions, but not the rationale that led to a specific answer. ",
                "link": null
              },
