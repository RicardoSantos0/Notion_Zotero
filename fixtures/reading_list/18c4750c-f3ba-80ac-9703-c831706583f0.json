    {
      "id": "1924750c-f3ba-8010-b5a5-f80283b0cccc",
      "type": "paragraph",
      "text": "KT often revolves around using previous questions to predict whether the next question will be correctly answered. One of the main drawbacks of the traditional KT approaches is that it only considers correctedness of previous questions, but not the rationale that led to a specific answer. ",
      "raw": {
        "object": "block",
        "id": "1924750c-f3ba-8010-b5a5-f80283b0cccc",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-80ac-9703-c831706583f0"
        },
        "created_time": "2025-02-06T15:34:00.000Z",
        "last_edited_time": "2025-02-06T15:35:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
