  "tables": [
    {
      "block_id": "1ca4750c-f3ba-8080-b6d3-d0ac5497dffc",
      "heading": "Abstract",
      "rows": [
        [
          "Task",
          "Context",
          "Student Performance Definition",
          "Target",
