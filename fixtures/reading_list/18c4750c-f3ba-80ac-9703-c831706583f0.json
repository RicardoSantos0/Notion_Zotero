    {
      "id": "1924750c-f3ba-8078-b8d0-cf5c15f813b8",
      "type": "paragraph",
      "text": "Authors use unsupervised learning on clickstream data to identify different patterns of question-answering behavior. This is followed by Clickstream KT, a model that is standard KT that also considers clickstream data within its parameters. Results show that inserting clickstream leads to better performance of the KT models.",
      "raw": {
        "object": "block",
        "id": "1924750c-f3ba-8078-b8d0-cf5c15f813b8",
        "parent": {
          "type": "page_id",
