    {
      "id": "44cbeabe-ee97-4705-8071-263a76a3a5ac",
      "type": "paragraph",
      "text": "There are few works that attempt to use interactions between elements in a context of collaborative learning to predict student performance. Authors use data from a PBL-course with a final group project. Authors build an interaction graph based on the activities of students in their teams.",
      "raw": {
        "object": "block",
        "id": "44cbeabe-ee97-4705-8071-263a76a3a5ac",
        "parent": {
          "type": "page_id",
          "page_id": "733c47cf-06d8-4c42-a69e-307851501b00"
        },
        "created_time": "2024-08-05T19:04:00.000Z",
        "last_edited_time": "2024-08-05T19:06:00.000Z",
