    {
      "id": "1b64750c-f3ba-8030-9625-c6b35777749a",
      "type": "paragraph",
      "text": "Educational recommender systems have problems with cold-start but also require learners to have pre-requisite knowledge to fully comprehend the received recommendation. The approach starts with creating pairs between concepts and pre-requisites and making this form of labelling using ML. ",
      "raw": {
        "object": "block",
        "id": "1b64750c-f3ba-8030-9625-c6b35777749a",
        "parent": {
          "type": "page_id",
          "page_id": "352413f6-104f-431c-833b-d460084b56d5"
        },
        "created_time": "2025-03-14T17:52:00.000Z",
        "last_edited_time": "2025-03-14T17:57:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
