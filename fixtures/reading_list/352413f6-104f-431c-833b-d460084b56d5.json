        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Educational recommender systems have problems with cold-start but also require learners to have pre-requisite knowledge to fully comprehend the received recommendation. The approach starts with creating pairs between concepts and pre-requisites and making this form of labelling using ML. ",
                "link": null
              },
              "annotations": {
