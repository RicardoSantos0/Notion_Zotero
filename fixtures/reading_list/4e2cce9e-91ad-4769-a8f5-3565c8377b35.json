    {
      "id": "1b44750c-f3ba-8037-bda4-e3236ece982d",
      "type": "paragraph",
      "text": "Dealing with content overload is prolematic for e-learners, which suggests that a recommender system an effective measure to mitigate this issue. Authors propose a new recommender system based on knowledge building and performance analysis. ",
      "raw": {
        "object": "block",
        "id": "1b44750c-f3ba-8037-bda4-e3236ece982d",
        "parent": {
          "type": "page_id",
          "page_id": "4e2cce9e-91ad-4769-a8f5-3565c8377b35"
        },
        "created_time": "2025-03-12T21:25:00.000Z",
        "last_edited_time": "2025-03-12T21:26:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
