    {
      "id": "18d4750c-f3ba-80b3-bca4-f5a2fdf33c3b",
      "type": "paragraph",
      "text": "There is close to no research highlighting differences in help-seeking behaviour when it comes to asking help to humans or to GenAI. Authors use multi-modal data to compare help-seeking between 2 groups of students. Comparison is done using Statistical tests and process mining.",
      "raw": {
        "object": "block",
        "id": "18d4750c-f3ba-80b3-bca4-f5a2fdf33c3b",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-806c-b5af-fc5a7890e8d8"
        },
        "created_time": "2025-02-01T17:50:00.000Z",
        "last_edited_time": "2025-02-01T17:55:00.000Z",
        "created_by": {
