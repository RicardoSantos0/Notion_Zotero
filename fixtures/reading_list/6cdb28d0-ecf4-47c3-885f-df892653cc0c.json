    {
      "id": "1b34750c-f3ba-80f0-9304-cf2fb869d444",
      "type": "paragraph",
      "text": "Authors propose a recommender system to facilitate college selection to international students. The RS uses Structural Topic Modelling to model the answers into latent variables that explain college preferences.",
      "raw": {
        "object": "block",
        "id": "1b34750c-f3ba-80f0-9304-cf2fb869d444",
        "parent": {
          "type": "page_id",
          "page_id": "6cdb28d0-ecf4-47c3-885f-df892653cc0c"
        },
        "created_time": "2025-03-11T13:24:00.000Z",
        "last_edited_time": "2025-03-11T13:25:00.000Z",
