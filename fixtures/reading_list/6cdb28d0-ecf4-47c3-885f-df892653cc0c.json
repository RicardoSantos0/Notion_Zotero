    {
      "id": "1b34750c-f3ba-804d-8101-f52804bd3d28",
      "type": "paragraph",
      "text": "The model uses TOEFL scores as inputs to recommend any additional college the learner may be interested into. Introducing the year in which the candidate took the TOEFL test brings marginal contributions to the recommender. ",
      "raw": {
        "object": "block",
        "id": "1b34750c-f3ba-804d-8101-f52804bd3d28",
