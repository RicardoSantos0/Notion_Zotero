    {
      "id": "1b34750c-f3ba-80ac-8c75-ff4036cca656",
      "type": "paragraph",
      "text": "Embedding context awareness in recommender systems has been shown to increase the accuracy of the recommender. In education, these CARS often are less trusted because the information provided needs to be trustworthy. ",
      "raw": {
        "object": "block",
        "id": "1b34750c-f3ba-80ac-8c75-ff4036cca656",
        "parent": {
          "type": "page_id",
          "page_id": "c78acb0e-3d17-413d-9c01-3c4f95b0a5a2"
        },
        "created_time": "2025-03-11T13:19:00.000Z",
        "last_edited_time": "2025-03-11T13:20:00.000Z",
        "created_by": {
