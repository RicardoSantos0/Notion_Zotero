    {
      "block_id": "1ce4750c-f3ba-802e-afce-d9132118eb5e",
      "heading": "Summary Table KT",
      "rows": [
        [
          "Task",
          "Context",
          "Student Performance Definition",
          "Target",
          "Students",
          "Courses",
          "Data sources",
