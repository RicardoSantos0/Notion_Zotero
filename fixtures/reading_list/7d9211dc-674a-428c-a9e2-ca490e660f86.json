    {
      "id": "4803f19e-3cc5-44af-8511-70ccbda44dda",
      "type": "paragraph",
      "text": "Learner sourcing platforms often rely on multiple choice questions to assess students. While a mechanism for feedback, this system introduces noise that hinders the ability of predictive models to make a correct prediction about student dropout or overall performance. This noise is often generated by a model’s inability to semantically distinguish between a correct and an incorrect answer. ",
      "raw": {
        "object": "block",
        "id": "4803f19e-3cc5-44af-8511-70ccbda44dda",
        "parent": {
          "type": "page_id",
          "page_id": "7d9211dc-674a-428c-a9e2-ca490e660f86"
        },
        "created_time": "2024-08-06T16:24:00.000Z",
        "last_edited_time": "2024-08-06T16:27:00.000Z",
        "created_by": {
