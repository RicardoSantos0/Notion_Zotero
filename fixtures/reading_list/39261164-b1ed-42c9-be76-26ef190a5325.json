    {
      "id": "1b14750c-f3ba-803c-92a8-ea9dd21ea42b",
      "type": "paragraph",
      "text": "Dynamic group formation (groups that adjust) is helpful in computer supported collaborative learning settings. The work explores how groups are formed in an ITS designed for collaborative learning and evaluate the user experience of their users. Feedback is collected via a questionnaire. ",
      "raw": {
        "object": "block",
        "id": "1b14750c-f3ba-803c-92a8-ea9dd21ea42b",
        "parent": {
          "type": "page_id",
          "page_id": "39261164-b1ed-42c9-be76-26ef190a5325"
        },
        "created_time": "2025-03-09T15:21:00.000Z",
        "last_edited_time": "2025-03-09T15:46:00.000Z",
        "created_by": {
