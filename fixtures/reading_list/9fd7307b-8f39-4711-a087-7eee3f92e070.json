    {
      "id": "223f239a-66f5-435b-97f2-95f062759f2a",
      "type": "paragraph",
      "text": "Most methods for the prediction of student performance tend to focus on attributes of the students and not as much in the relationships between the students themselves. The paper introduces a framelet-nased dual hypergraph neeural network  that decomposes student features in order to obtain model student relatinships.",
      "raw": {
        "object": "block",
        "id": "223f239a-66f5-435b-97f2-95f062759f2a",
        "parent": {
          "type": "page_id",
          "page_id": "9fd7307b-8f39-4711-a087-7eee3f92e070"
        },
        "created_time": "2024-08-06T17:50:00.000Z",
        "last_edited_time": "2025-08-27T20:11:00.000Z",
