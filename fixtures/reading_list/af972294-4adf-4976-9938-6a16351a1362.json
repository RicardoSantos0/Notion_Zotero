    {
      "id": "cb96b16a-b5d2-4fa1-bca2-0c1035f013d1",
      "type": "paragraph",
      "text": "Assessing elearning quality is often contingent on using early warning systems to predict learning outcomes. To improve on current state fo the art, the authors propose 2 new methods: BCEP and BCP that perform feature extraction on behavioral attributes. ",
      "raw": {
        "object": "block",
        "id": "cb96b16a-b5d2-4fa1-bca2-0c1035f013d1",
        "parent": {
          "type": "page_id",
          "page_id": "af972294-4adf-4976-9938-6a16351a1362"
        },
        "created_time": "2024-08-04T18:06:00.000Z",
        "last_edited_time": "2024-08-04T18:23:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Assessing elearning quality is often contingent on using early warning systems to predict learning outcomes. To improve on current state fo the art, the authors propose 2 new methods: BCEP and BCP that perform feature extraction on behavioral attributes. ",
                "link": null
              },
