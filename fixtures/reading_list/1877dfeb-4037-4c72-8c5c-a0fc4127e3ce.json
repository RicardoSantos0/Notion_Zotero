    {
      "id": "1f91c7b7-f6bd-407d-8396-7ecc861b81cf",
      "type": "paragraph",
      "text": "Student performance prediction is an important task in Learning Analytics. A significant issue with the current student performance prediction models relates with the fact that most models treat students as independent (no relationship between learners). ",
      "raw": {
        "object": "block",
        "id": "1f91c7b7-f6bd-407d-8396-7ecc861b81cf",
        "parent": {
          "type": "page_id",
          "page_id": "1877dfeb-4037-4c72-8c5c-a0fc4127e3ce"
        },
        "created_time": "2024-08-05T13:42:00.000Z",
        "last_edited_time": "2024-08-05T13:47:00.000Z",
