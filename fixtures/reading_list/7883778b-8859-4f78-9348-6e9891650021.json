    {
      "id": "6eb81885-8d46-4aa3-ad6f-508059a12842",
      "type": "paragraph",
      "text": "The authors explore the effectiveness of LSTM to predict end of course performance in an online University. Results obtained on OULAD dataset show that this approach greatly outperforms the baseline Logistic Regression model, achieving 95.2% accuracy, 93% precision and 76% Recall. ",
      "raw": {
        "object": "block",
        "id": "6eb81885-8d46-4aa3-ad6f-508059a12842",
        "parent": {
          "type": "page_id",
          "page_id": "7883778b-8859-4f78-9348-6e9891650021"
        },
        "created_time": "2024-07-31T17:58:00.000Z",
        "last_edited_time": "2024-07-31T18:01:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
