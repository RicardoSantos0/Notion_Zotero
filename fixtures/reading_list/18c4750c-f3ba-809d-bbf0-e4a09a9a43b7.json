    {
      "id": "1ad4750c-f3ba-8007-919e-e1ce318eb944",
      "type": "paragraph",
      "text": "LMS have shown to foster a sense of community and progress among the student population and have consequently become a cornerstone of higher education institutions. Authors take data from one institution and analyze the usage patterns of the LMS in relation to student outcomes. ",
      "raw": {
        "object": "block",
        "id": "1ad4750c-f3ba-8007-919e-e1ce318eb944",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-809d-bbf0-e4a09a9a43b7"
        },
        "created_time": "2025-03-05T14:00:00.000Z",
        "last_edited_time": "2025-03-05T15:04:00.000Z",
