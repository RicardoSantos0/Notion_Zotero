    {
      "block_id": "1ce4750c-f3ba-800f-9e1e-f5926453281d",
      "heading": "Summary Table KT",
      "rows": [
        [
          "Task",
          "Context",
          "Student Performance Definition",
          "Target",
          "Students",
          "Courses",
          "Data sources",
          "Features",
          "Flaw of Previous Models",
          "Novelty of Model",
