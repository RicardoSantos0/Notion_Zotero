    {
      "id": "1924750c-f3ba-8088-85bf-f13f87391a0a",
      "type": "paragraph",
      "text": "KT in online settings has some differences to other contexts, as online questions are often associated with a smaller set of skills but tend to be more and more common. Thus, KT works in online settings could explore problems that sparse dataset cannot - such as question-skill correlations.  ",
      "raw": {
        "object": "block",
        "id": "1924750c-f3ba-8088-85bf-f13f87391a0a",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-80d9-b19c-fa43615c73bd"
        },
        "created_time": "2025-02-06T19:38:00.000Z",
        "last_edited_time": "2025-02-06T19:43:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "KT in online settings has some differences to other contexts, as online questions are often associated with a smaller set of skills but tend to be more and more common. Thus, KT works in online settings could explore problems that sparse dataset cannot - such as question-skill correlations.  ",
                "link": null
              },
              "annotations": {
