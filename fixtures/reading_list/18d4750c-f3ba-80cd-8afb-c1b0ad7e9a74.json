    {
      "id": "1924750c-f3ba-809f-b014-f40a07743b0b",
      "type": "paragraph",
      "text": "Early work on early warning systems focused on course-agnostic and portable models. However, with time, the flaws in this approach have surfaced more and more. This work attempts to do early prediction on a subset of similar courses while simultaneously considering differences between the courses considered. This iis done using mixed effect linear regression models.",
      "raw": {
        "object": "block",
        "id": "1924750c-f3ba-809f-b014-f40a07743b0b",
        "parent": {
          "type": "page_id",
          "page_id": "18d4750c-f3ba-80cd-8afb-c1b0ad7e9a74"
        },
        "created_time": "2025-02-06T11:44:00.000Z",
        "last_edited_time": "2025-02-06T13:09:00.000Z",
