      "block_id": "1b94750c-f3ba-8001-a5da-e08fdf1a3bcd",
      "heading": "Abstract",
      "rows": [
        [
          "Task",
          "Context",
          "Student Performance Definition",
          "Target",
          "Students",
          "Courses",
          "Data sources",
          "Features",
