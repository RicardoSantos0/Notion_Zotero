    {
      "id": "2051c98e-a8d1-417d-a914-fb94193e0223",
      "type": "paragraph",
      "text": "Results show that RNN surpasses conventional classifiers and achieves similar performance to the CNN model. Moreover, identification is passive after a third of the semester has passed.",
      "raw": {
        "object": "block",
        "id": "2051c98e-a8d1-417d-a914-fb94193e0223",
        "parent": {
