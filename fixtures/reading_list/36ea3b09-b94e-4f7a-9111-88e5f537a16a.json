    {
      "id": "539717fc-11f8-4c0a-858a-c46ea318db61",
      "type": "paragraph",
      "text": "Authors use data from an Online course in a Taiwanese university. Authors extract multiple features and train their RNN models and benchmark it against other alternatives: SVM, LR, DT, RF, CNN based model and a standard MLP. ",
      "raw": {
        "object": "block",
        "id": "539717fc-11f8-4c0a-858a-c46ea318db61",
        "parent": {
          "type": "page_id",
          "page_id": "36ea3b09-b94e-4f7a-9111-88e5f537a16a"
        },
        "created_time": "2024-08-02T19:35:00.000Z",
        "last_edited_time": "2024-08-02T19:36:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Authors use data from an Online course in a Taiwanese university. Authors extract multiple features and train their RNN models and benchmark it against other alternatives: SVM, LR, DT, RF, CNN based model and a standard MLP. ",
                "link": null
              },
              "annotations": {
                "bold": false,
