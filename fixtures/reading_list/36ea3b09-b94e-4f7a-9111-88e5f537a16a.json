    {
      "id": "81d4fe8f-64a9-4e67-bd0b-5128795b42d2",
      "type": "paragraph",
      "text": "CNN models are the most common models used for prediction of learning outcomes (?). Authors argue that RNN based models are more adequate for the task of identifying students at risk. ",
      "raw": {
        "object": "block",
        "id": "81d4fe8f-64a9-4e67-bd0b-5128795b42d2",
        "parent": {
          "type": "page_id",
          "page_id": "36ea3b09-b94e-4f7a-9111-88e5f537a16a"
        },
        "created_time": "2024-08-02T19:32:00.000Z",
        "last_edited_time": "2024-08-02T19:35:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
