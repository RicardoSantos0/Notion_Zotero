    {
      "id": "58dc0804-9cc1-4508-9146-e7215c690a20",
      "type": "paragraph",
      "text": "LA serve multiple purposes in modern educational contexts and many of the predictive models for dropout usually work better on a smaller subset of courses or a single course, with few works actually working with large numbers of courses.",
      "raw": {
        "object": "block",
        "id": "58dc0804-9cc1-4508-9146-e7215c690a20",
        "parent": {
          "type": "page_id",
          "page_id": "645771b9-299e-43f5-a286-ccc43392b995"
        },
