  "tables": [
    {
      "block_id": "1c64750c-f3ba-80c9-8048-ef4f0b7603d3",
      "heading": "Summary Table DESC",
      "rows": [
        [
          "Task",
          "Context",
          "Teaching Method",
          "Students",
