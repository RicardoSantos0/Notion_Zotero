    {
      "id": "1914750c-f3ba-8019-a4d4-dfdc4f787c6a",
      "type": "paragraph",
      "text": "Authors attempt to model procrastination as part of a continuum by using a Multi-dimensional Hawkes approach. Essentially, the authors use this approach to model exogenous events (deadlines) and endogenous events (responses within and between types of learning materials). ",
      "raw": {
        "object": "block",
        "id": "1914750c-f3ba-8019-a4d4-dfdc4f787c6a",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-8010-9cc5-f7c88979ec06"
        },
        "created_time": "2025-02-05T15:48:00.000Z",
        "last_edited_time": "2025-03-30T14:24:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Authors attempt to model procrastination as part of a continuum by using a Multi-dimensional Hawkes approach. Essentially, the authors use this approach to model exogenous events (deadlines) and endogenous events (responses within and between types of learning materials). ",
                "link": null
