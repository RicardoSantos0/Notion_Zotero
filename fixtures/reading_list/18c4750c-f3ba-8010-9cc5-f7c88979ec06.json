    {
      "id": "1914750c-f3ba-80bd-924a-e4afd58afd24",
      "type": "paragraph",
      "text": "Procrastination is harmful effects to student well-being and ability to learn and its effects are even more pronounced in online settings (MOOCs). Modelling procrastination has been attempted before and the most relevant representations are either static or as parameters of constant-rate temporal models (usually discrete events). ",
      "raw": {
        "object": "block",
        "id": "1914750c-f3ba-80bd-924a-e4afd58afd24",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-8010-9cc5-f7c88979ec06"
        },
        "created_time": "2025-02-05T15:37:00.000Z",
        "last_edited_time": "2025-02-05T15:48:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Procrastination is harmful effects to student well-being and ability to learn and its effects are even more pronounced in online settings (MOOCs). Modelling procrastination has been attempted before and the most relevant representations are either static or as parameters of constant-rate temporal models (usually discrete events). ",
                "link": null
              },
              "annotations": {
