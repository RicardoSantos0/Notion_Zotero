    {
      "id": "1ab4750c-f3ba-80b6-9e7f-fffdb3a0ee98",
      "type": "paragraph",
      "text": "Interpreting SRL attributes merely from behavior is challenging due to potential differences in task and context. Authors propose a new method to extract SRL processes to a dataset of a multi-source writing task. ",
      "raw": {
        "object": "block",
        "id": "1ab4750c-f3ba-80b6-9e7f-fffdb3a0ee98",
        "parent": {
          "type": "page_id",
          "page_id": "37e165b9-900c-4986-acc7-2b8ba2298261"
        },
        "created_time": "2025-03-03T22:24:00.000Z",
        "last_edited_time": "2025-03-03T22:26:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Interpreting SRL attributes merely from behavior is challenging due to potential differences in task and context. Authors propose a new method to extract SRL processes to a dataset of a multi-source writing task. ",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
