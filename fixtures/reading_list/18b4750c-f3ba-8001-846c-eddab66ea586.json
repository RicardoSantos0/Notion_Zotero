  "tables": [
    {
      "block_id": "1ce4750c-f3ba-809d-8839-ff20c20de3b8",
      "heading": "Abstract",
      "rows": [
        [
          "Task",
          "Context",
          "Student Performance Definition",
          "Target",
          "Students",
          "Courses",
          "Data sources",
          "Features",
          "Flaw of Previous Models",
