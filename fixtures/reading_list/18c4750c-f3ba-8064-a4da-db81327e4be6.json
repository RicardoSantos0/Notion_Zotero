    {
      "id": "18d4750c-f3ba-80d6-b083-fba56ce1fff9",
      "type": "paragraph",
      "text": "To address the problems with BKT convergence, authors propose a new form of optimizing BKT OptimNN which is meant to use a NN to train BKT parameters. This is later extended into BKTransformer, which generates parameters for BKT that evolve with time. ",
      "raw": {
        "object": "block",
        "id": "18d4750c-f3ba-80d6-b083-fba56ce1fff9",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-8064-a4da-db81327e4be6"
        },
        "created_time": "2025-02-01T18:01:00.000Z",
        "last_edited_time": "2025-02-01T18:03:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
