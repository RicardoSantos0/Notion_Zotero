    {
      "id": "18d4750c-f3ba-805f-b196-c9e55d306f0f",
      "type": "paragraph",
      "text": "Bayesian Knowledge Tracing, while useful and well-established, is known to have some convergence problems that lead it to converge in undesirable local minima (parameter degeneracy). Deep Knowledge Tracing achieves better performance but is often not interpretable - a significant issue in student response correctedness scenarios.",
      "raw": {
        "object": "block",
        "id": "18d4750c-f3ba-805f-b196-c9e55d306f0f",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-8064-a4da-db81327e4be6"
        },
        "created_time": "2025-02-01T17:57:00.000Z",
        "last_edited_time": "2025-02-01T18:03:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
