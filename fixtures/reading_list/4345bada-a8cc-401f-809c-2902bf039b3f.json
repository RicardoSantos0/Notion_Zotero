    {
      "id": "1944750c-f3ba-8023-b935-fb5a18c1af12",
      "type": "paragraph",
      "text": "Authors use mutidimensional IRT and KT techniques to be able to diagnose a learner’s skills (so, first step is the creation of a knowledge model). Then, this model based on MIRT is used as input to a collaborative filtering algorithm for course recommendations. ",
      "raw": {
        "object": "block",
        "id": "1944750c-f3ba-8023-b935-fb5a18c1af12",
        "parent": {
          "type": "page_id",
          "page_id": "4345bada-a8cc-401f-809c-2902bf039b3f"
        },
        "created_time": "2025-02-08T21:48:00.000Z",
