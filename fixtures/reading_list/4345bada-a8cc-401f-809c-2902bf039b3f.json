  "tables": [
    {
      "block_id": "23c4750c-f3ba-80f0-bddd-ef9300f19401",
      "heading": "Summary Table REC",
      "rows": [
        [
          "Context",
          "Teaching Method",
          "Recommender System Type",
          "Target of Recommendation",
