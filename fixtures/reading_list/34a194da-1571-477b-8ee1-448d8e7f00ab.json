    {
      "id": "5b727d32-6a8e-48dd-a133-358f4af762f0",
      "type": "paragraph",
      "text": "A limitation of the current embedding based representations of KT models is the fact that the number of questions is often fixed. Thus, when EdTech platforms add new questions, the current models cannot follow this update. ",
      "raw": {
        "object": "block",
        "id": "5b727d32-6a8e-48dd-a133-358f4af762f0",
        "parent": {
          "type": "page_id",
          "page_id": "34a194da-1571-477b-8ee1-448d8e7f00ab"
        },
        "created_time": "2024-08-06T18:41:00.000Z",
        "last_edited_time": "2024-08-06T18:43:00.000Z",
