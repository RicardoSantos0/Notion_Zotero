    {
      "id": "2d1a1865-40b8-4dbf-868e-deec86cba412",
      "type": "paragraph",
      "text": "Blended learning mixes F2F classes with Online Learning and LA is meant to help identify students early and provide timely interventions based on student learner profiles. Authors extract a set of multiple variables, ranging from video-watching behaviors to homework and quiz scores. ",
      "raw": {
        "object": "block",
        "id": "2d1a1865-40b8-4dbf-868e-deec86cba412",
        "parent": {
          "type": "page_id",
          "page_id": "f1a2ba53-d9c5-49d4-b0dc-e9e4e1edc6fa"
        },
        "created_time": "2024-07-31T15:22:00.000Z",
        "last_edited_time": "2024-07-31T15:25:00.000Z",
