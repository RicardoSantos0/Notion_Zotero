    {
      "id": "18f4750c-f3ba-80af-bbfb-e0a544db74ab",
      "type": "paragraph",
      "text": "The paper compares a group formation proposal (activity-based) against a baseline grouping function of the platform. Approaches are compared in terms of group performance, activity and student satisfaction. ",
      "raw": {
        "object": "block",
        "id": "18f4750c-f3ba-80af-bbfb-e0a544db74ab",
