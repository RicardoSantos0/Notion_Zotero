    {
      "id": "573c25c2-e776-4278-a6fd-b1f0bbdf0c90",
      "type": "paragraph",
      "text": "Work starts with the prediction of student performance from data collected at an Australian University. Enrollment details and LMS data. Authors also make an attempt to consider student heterogeneity. To do that, the authors create models that are specific to different student sub-populations.",
      "raw": {
        "object": "block",
        "id": "573c25c2-e776-4278-a6fd-b1f0bbdf0c90",
        "parent": {
          "type": "page_id",
          "page_id": "c4bf8af8-477e-4e1c-bf0c-7351a31e6ace"
        },
        "created_time": "2024-07-31T17:13:00.000Z",
        "last_edited_time": "2024-07-31T17:15:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Work starts with the prediction of student performance from data collected at an Australian University. Enrollment details and LMS data. Authors also make an attempt to consider student heterogeneity. To do that, the authors create models that are specific to different student sub-populations.",
                "link": null
              },
              "annotations": {
