    {
      "id": "10df77fc-98ca-48b1-8798-105ee89900b0",
      "type": "paragraph",
      "text": "Procrastination behavior is a negatively affects student performance. Work intends to measure procrastination behavior based on Moodle submission Logs. ",
      "raw": {
        "object": "block",
        "id": "10df77fc-98ca-48b1-8798-105ee89900b0",
        "parent": {
