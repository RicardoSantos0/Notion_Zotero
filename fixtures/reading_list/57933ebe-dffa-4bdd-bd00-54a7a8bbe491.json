    {
      "id": "1b44750c-f3ba-8039-85ad-f78b450161f3",
      "type": "paragraph",
      "text": "Engagement is an important measure to track in collaborative learning, but little research is dedicated towards exploring multi-modal sources of data to understand behavior in face-to-face settings. ",
      "raw": {
        "object": "block",
        "id": "1b44750c-f3ba-8039-85ad-f78b450161f3",
        "parent": {
          "type": "page_id",
          "page_id": "57933ebe-dffa-4bdd-bd00-54a7a8bbe491"
        },
        "created_time": "2025-03-12T21:42:00.000Z",
        "last_edited_time": "2025-03-12T21:43:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Engagement is an important measure to track in collaborative learning, but little research is dedicated towards exploring multi-modal sources of data to understand behavior in face-to-face settings. ",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
                "underline": false,
