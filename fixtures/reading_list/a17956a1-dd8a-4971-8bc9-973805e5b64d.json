    {
      "id": "6dffbd22-8a0a-4371-9ecb-47149576f977",
      "type": "paragraph",
      "text": "Courses such as algorithms and programming have very high rates of dropout. Authors create multiple early detection algorithms with different pre-processing techniques to identify which combinations generate the best predictions. ",
      "raw": {
        "object": "block",
        "id": "6dffbd22-8a0a-4371-9ecb-47149576f977",
        "parent": {
          "type": "page_id",
          "page_id": "a17956a1-dd8a-4971-8bc9-973805e5b64d"
        },
        "created_time": "2024-07-31T20:52:00.000Z",
        "last_edited_time": "2024-07-31T20:54:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Courses such as algorithms and programming have very high rates of dropout. Authors create multiple early detection algorithms with different pre-processing techniques to identify which combinations generate the best predictions. ",
