    {
      "id": "440b896d-8435-4d15-aeb7-8d3ab3e3060d",
      "type": "paragraph",
      "text": "Authors found that LMS and Institutional data are, indeed, predictive of student performance and that performance is increased when both sources are combined. However, the authors also identified that under-represented groups tend to have their performance be under-estimated, meaning that these students may, under the current regimen, be more likely to slip through the cracks of a warning system. ",
      "raw": {
        "object": "block",
        "id": "440b896d-8435-4d15-aeb7-8d3ab3e3060d",
        "parent": {
          "type": "page_id",
          "page_id": "6a683d55-58fa-45c4-bf37-6758b22969e4"
        },
        "created_time": "2024-07-31T22:04:00.000Z",
        "last_edited_time": "2024-07-31T22:06:00.000Z",
