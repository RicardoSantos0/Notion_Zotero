    {
      "id": "0c2122e3-de58-48ad-a370-4a01501bc7a8",
      "type": "paragraph",
      "text": "Learning analytics predictive models are not always fair to all student subgroups. To show this, authors compare the effectiveness of features extracted from 3 different data sources: SIS, LMS and Survey. The analysis is made in a 2-fold manner:",
      "raw": {
        "object": "block",
        "id": "0c2122e3-de58-48ad-a370-4a01501bc7a8",
        "parent": {
          "type": "page_id",
          "page_id": "6a683d55-58fa-45c4-bf37-6758b22969e4"
        },
        "created_time": "2024-07-31T22:03:00.000Z",
        "last_edited_time": "2024-07-31T22:04:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
