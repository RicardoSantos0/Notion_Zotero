  "tables": [
    {
      "block_id": "1ce4750c-f3ba-80ac-8b49-eadd4f01221e",
      "heading": "Summary Table KT",
      "rows": [
        [
          "Task",
          "Context",
          "Student Performance Definition",
          "Target",
          "Students",
          "Courses",
          "Data sources",
          "Features",
          "Flaw of Previous Models",
          "Novelty of Model",
