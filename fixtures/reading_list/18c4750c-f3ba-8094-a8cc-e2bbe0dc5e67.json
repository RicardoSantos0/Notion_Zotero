    {
      "id": "1914750c-f3ba-8097-aea2-f080cf5dd4ff",
      "type": "paragraph",
      "text": "Students learn from multiple resources and an effective learner representation should probably account for them as it would allow for an effective detection of knowledge gaps and recommendation of learning materials. KT traditionally only uses problems for this modelling, ignoring other forms of materials. ",
      "raw": {
        "object": "block",
        "id": "1914750c-f3ba-8097-aea2-f080cf5dd4ff",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-8094-a8cc-e2bbe0dc5e67"
        },
        "created_time": "2025-02-05T18:12:00.000Z",
        "last_edited_time": "2025-02-05T18:21:00.000Z",
