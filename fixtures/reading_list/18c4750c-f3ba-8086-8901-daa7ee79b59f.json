    {
      "id": "1ad4750c-f3ba-8095-a19b-edfc96d6e85e",
      "type": "paragraph",
      "text": "Formative assessments are a tool that exists but that is often underexplored. The study investigates learner engagement with self-assessments to see if and how they affect student performance. Approach is tested on a sample of students taking a BSc in Economic and Business Education and, throughout the semester were asked to do multiple self-assessments.",
      "raw": {
        "object": "block",
        "id": "1ad4750c-f3ba-8095-a19b-edfc96d6e85e",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-8086-8901-daa7ee79b59f"
        },
        "created_time": "2025-03-05T16:09:00.000Z",
        "last_edited_time": "2025-03-05T16:12:00.000Z",
        "created_by": {
          "object": "user",
