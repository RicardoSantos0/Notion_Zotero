    {
      "id": "1ae4750c-f3ba-801a-a942-c9042463ed6c",
      "type": "paragraph",
      "text": "The work explores the usage of Logs in maker-based pedagogy to generate evidence of SRL. The authors use frequencies and sequential patterns for that using a mixed-method approach. They developed a log-based analytic framework for development of SRL phases for maker activities. ",
      "raw": {
        "object": "block",
        "id": "1ae4750c-f3ba-801a-a942-c9042463ed6c",
        "parent": {
          "type": "page_id",
          "page_id": "3f51854c-9789-406f-b81b-47220fd2049e"
        },
        "created_time": "2025-03-06T16:10:00.000Z",
        "last_edited_time": "2025-03-06T17:15:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "The work explores the usage of Logs in maker-based pedagogy to generate evidence of SRL. The authors use frequencies and sequential patterns for that using a mixed-method approach. They developed a log-based analytic framework for development of SRL phases for maker activities. ",
                "link": null
              },
              "annotations": {
                "bold": false,
