    {
      "id": "1924750c-f3ba-807a-9cf5-df15f17fb2a2",
      "type": "paragraph",
      "text": "ITS create learner models to measure learning and propose new pedagogical decisions. The paper introduces a Logistic Knowledge Tracing model. The authors use the framework to fit 12 models to 6 learning technology datasets. ",
      "raw": {
        "object": "block",
        "id": "1924750c-f3ba-807a-9cf5-df15f17fb2a2",
        "parent": {
          "type": "page_id",
          "page_id": "18b4750c-f3ba-804e-84e1-f723b57d34a6"
        },
        "created_time": "2025-02-06T19:34:00.000Z",
        "last_edited_time": "2025-02-06T19:35:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
