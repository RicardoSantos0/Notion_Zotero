    {
      "id": "1ab4750c-f3ba-805e-beaa-d0a7449cec06",
      "type": "paragraph",
      "text": "Online judges are often used to help in programming training, but often do not evaluate the degree of mastery of programming skills (often focusing on works vs doesn’t work). Deep knowledge tracing models have been used, but often assume a task requires one skill only.",
      "raw": {
        "object": "block",
        "id": "1ab4750c-f3ba-805e-beaa-d0a7449cec06",
        "parent": {
          "type": "page_id",
          "page_id": "4ee13ed4-1a65-42a5-97a5-699a9b8cb7d5"
        },
        "created_time": "2025-03-03T22:30:00.000Z",
        "last_edited_time": "2025-03-03T22:32:00.000Z",
        "created_by": {
          "object": "user",
