    {
      "id": "8a5c9685-2a3a-4565-9f2a-698121244fc4",
      "type": "paragraph",
      "text": "Insufficient representation is a common cause of weak spots in predictive models. The paper intends to provide explanatory potential for areas where a predictive model may fail - called unknown unknowns (situations where a model is very confident but gets the prediction wrong).",
      "raw": {
        "object": "block",
        "id": "8a5c9685-2a3a-4565-9f2a-698121244fc4",
        "parent": {
          "type": "page_id",
