    {
      "id": "0d05a1a4-9065-4b90-9d14-5892c45142c6",
      "type": "paragraph",
      "text": "The authors start from the perspective that there are very few attempts at using Deep Learning to address the student performance prediction problem. The authors, thus, propose a Bi-Directional LSTM based model that treats the problem of student performance prediction as a sequential event prediction problem.",
      "raw": {
        "object": "block",
        "id": "0d05a1a4-9065-4b90-9d14-5892c45142c6",
        "parent": {
          "type": "page_id",
          "page_id": "20da9077-6da4-49b4-8ca3-ab1ac8d3f33f"
        },
        "created_time": "2024-07-31T15:45:00.000Z",
        "last_edited_time": "2024-07-31T15:46:00.000Z",
        "created_by": {
