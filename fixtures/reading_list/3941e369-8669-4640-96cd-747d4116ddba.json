    {
      "id": "1924750c-f3ba-8087-a343-e35bb72fb6d9",
      "type": "paragraph",
      "text": "Trace data has historically been used to identify different learning tactics. Authors propose a learning approach to identify and compare learning tactics. Authors identify 4 learning tactics in data from 728 learners and theorize five micro-processes.",
      "raw": {
        "object": "block",
        "id": "1924750c-f3ba-8087-a343-e35bb72fb6d9",
        "parent": {
          "type": "page_id",
          "page_id": "3941e369-8669-4640-96cd-747d4116ddba"
        },
        "created_time": "2025-02-06T21:54:00.000Z",
        "last_edited_time": "2025-02-06T22:05:00.000Z",
        "created_by": {
