    {
      "id": "1ab4750c-f3ba-8062-9a78-f40c29b491c7",
      "type": "paragraph",
      "text": "Learners from an online ERS should have the same opportunities. The authors propose a set of possible avenues that could be considered towards ensuring equal opportunity in ERS, among them being a new metric by which to evaluate ERS. ",
      "raw": {
        "object": "block",
        "id": "1ab4750c-f3ba-8062-9a78-f40c29b491c7",
        "parent": {
          "type": "page_id",
          "page_id": "133c4fbd-ae35-4ae7-97fc-4e354d976fa2"
        },
        "created_time": "2025-03-03T23:30:00.000Z",
        "last_edited_time": "2025-03-03T23:32:00.000Z",
