    {
      "id": "1914750c-f3ba-8048-bf65-e59bfeb8efbb",
      "type": "paragraph",
      "text": "The fitness functions used in Genetic Algorithms for group formation may have, as unintended consequence, the creation of imbalanced groups. The authors propose a new Genetic Algorithm formation that looks for homogeneous social interactions despite heteregenous knowledge-levels. The authors compare the effectiveness of their approach against self-selection and random group formation.",
      "raw": {
        "object": "block",
        "id": "1914750c-f3ba-8048-bf65-e59bfeb8efbb",
        "parent": {
          "type": "page_id",
          "page_id": "d45d80ad-28f6-407e-a253-73361c2c8178"
        },
        "created_time": "2025-02-05T12:36:00.000Z",
        "last_edited_time": "2025-02-05T12:46:00.000Z",
