    {
      "id": "535e24e3-4aac-42f1-94d0-90bd7d54d0cb",
      "type": "paragraph",
      "text": "Authors develop and present an Analytics Framework for Moodle. Moreover, the authors develop a case study of a MOOC offered at the school that includes 47000 students.",
      "raw": {
        "object": "block",
        "id": "535e24e3-4aac-42f1-94d0-90bd7d54d0cb",
        "parent": {
          "type": "page_id",
