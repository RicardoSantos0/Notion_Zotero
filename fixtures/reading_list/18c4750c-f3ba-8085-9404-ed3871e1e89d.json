    {
      "id": "1914750c-f3ba-8060-af3d-e2d4bf3f448b",
      "type": "paragraph",
      "text": "Collaborative Filtering algorithms tend to over-optimize for past behaviour, often leading to what is called a filter bubble. Authors try to address the issue in a course recommendation system at a HEI. This is done by using catalog descriptions (BOW) and enrollment histories (course2vec) to recommend novel and different courses.",
      "raw": {
        "object": "block",
        "id": "1914750c-f3ba-8060-af3d-e2d4bf3f448b",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-8085-9404-ed3871e1e89d"
        },
        "created_time": "2025-02-05T21:50:00.000Z",
        "last_edited_time": "2025-02-05T21:56:00.000Z",
