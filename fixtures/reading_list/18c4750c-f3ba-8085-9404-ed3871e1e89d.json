      "block_id": "1d84750c-f3ba-80e4-96cc-d0226541b025",
      "heading": "Abstract",
      "rows": [
        [
          "Context",
          "Teaching Method",
          "Recommender System Type",
          "Target of Recommendation",
          "Students",
          "Courses",
