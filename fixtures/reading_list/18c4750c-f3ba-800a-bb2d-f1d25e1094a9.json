    {
      "id": "1904750c-f3ba-809d-8f71-d91d53d82b5e",
      "type": "paragraph",
      "text": "Supporting student decision making is becoming increasingly important when more and more information is becoming available. This work builds on the literature of Deep Learning-Based Recommender systems meant to recommend courses meant to prepare them for target courses of interest. ",
      "raw": {
        "object": "block",
        "id": "1904750c-f3ba-809d-8f71-d91d53d82b5e",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-800a-bb2d-f1d25e1094a9"
        },
        "created_time": "2025-02-04T23:21:00.000Z",
        "last_edited_time": "2025-02-04T23:24:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
