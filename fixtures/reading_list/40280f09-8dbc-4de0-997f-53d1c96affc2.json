    {
      "id": "1b44750c-f3ba-807c-861f-e124dcc09c60",
      "type": "paragraph",
      "text": "The authors propose a learning analytics framework for collaborative learning which they coin as Group Learning Orchestrated Based on Evidence (GLOBE) which requires algorithmic group formation. The authors test their framework on 12 collaborative learning activities - testing both homogenous and heterogenous group formation.",
      "raw": {
        "object": "block",
        "id": "1b44750c-f3ba-807c-861f-e124dcc09c60",
        "parent": {
          "type": "page_id",
          "page_id": "40280f09-8dbc-4de0-997f-53d1c96affc2"
        },
        "created_time": "2025-03-12T17:07:00.000Z",
        "last_edited_time": "2025-03-12T17:24:00.000Z",
