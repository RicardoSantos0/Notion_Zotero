        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "Most LA work focuses on the use of supervised classifiers to predict students at risk. However, SSL approaches have shown to be superior to supervised methods. Moreover, Regression is also an underused method. ",
