    {
      "id": "1ae4750c-f3ba-8084-b741-e674b4a3430d",
      "type": "paragraph",
      "text": "The paper explores online help-seeking on a set of taiwanese HE students. Learners were asked to answer 2 surveys. Authors create 3 clusters - Adaptive, Socially-afiliated and self-reliant.",
      "raw": {
        "object": "block",
        "id": "1ae4750c-f3ba-8084-b741-e674b4a3430d",
        "parent": {
