    {
      "id": "2d764ee3-205d-4b1b-a59a-8a759d58502b",
      "type": "paragraph",
      "text": "VLEs have changed the paradigm of analytics for educational purposes as now more data than ever is available. This works deploys Deep Learning on a set of unique features to predict students at risk. ",
      "raw": {
        "object": "block",
        "id": "2d764ee3-205d-4b1b-a59a-8a759d58502b",
        "parent": {
          "type": "page_id",
          "page_id": "842eb923-1e04-4e3b-820b-74886a0e24c8"
        },
        "created_time": "2024-08-01T11:43:00.000Z",
        "last_edited_time": "2024-08-01T11:44:00.000Z",
