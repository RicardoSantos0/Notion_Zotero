    {
      "id": "1924750c-f3ba-80a8-9afa-c2bcc63c2420",
      "type": "paragraph",
      "text": "There is plenty of research using clickstream data to measure SRL in online courses. However, little research is dedicated to mapping SRL variables from LMS to actual SRL constructs in the literature. Thus, paper explores time management and effort regulation. ",
      "raw": {
        "object": "block",
        "id": "1924750c-f3ba-80a8-9afa-c2bcc63c2420",
        "parent": {
          "type": "page_id",
          "page_id": "6c0fcfdc-5dec-444c-9c7e-a02f87441bd5"
        },
        "created_time": "2025-02-06T19:49:00.000Z",
        "last_edited_time": "2025-02-06T20:33:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
