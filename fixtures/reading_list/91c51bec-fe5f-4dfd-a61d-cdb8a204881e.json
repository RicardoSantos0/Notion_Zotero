    {
      "id": "c37a15b8-c153-464d-b661-353163c8e87b",
      "type": "paragraph",
      "text": "A common way of performing semi-supervised learning is co-training. However, co-training requires redundant and conditionally independent dual views, something that does not seem to exist with enough abundance for this application. ",
      "raw": {
        "object": "block",
        "id": "c37a15b8-c153-464d-b661-353163c8e87b",
        "parent": {
          "type": "page_id",
          "page_id": "91c51bec-fe5f-4dfd-a61d-cdb8a204881e"
        },
        "created_time": "2024-08-05T14:00:00.000Z",
        "last_edited_time": "2024-08-05T14:03:00.000Z",
