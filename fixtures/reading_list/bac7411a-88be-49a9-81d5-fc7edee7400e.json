    {
      "id": "1b34750c-f3ba-8068-9ae1-c548e9afc246",
      "type": "paragraph",
      "text": "Elearning allows learners to access educational content whenever and wherever they desire. This new power also comes with the great responsability of enabling personalized learning, something that traditional Recommender systems often fail at due to making incorrect recommendations and, oftentimes, taking to long to properly reach the recommendation. ",
      "raw": {
        "object": "block",
        "id": "1b34750c-f3ba-8068-9ae1-c548e9afc246",
        "parent": {
          "type": "page_id",
          "page_id": "bac7411a-88be-49a9-81d5-fc7edee7400e"
        },
        "created_time": "2025-03-11T13:30:00.000Z",
        "last_edited_time": "2025-03-11T13:33:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
