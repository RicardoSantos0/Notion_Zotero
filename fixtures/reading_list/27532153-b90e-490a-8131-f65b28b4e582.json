    {
      "id": "ac46aeab-e180-40ec-a96d-4b6a00f5342e",
      "type": "paragraph",
      "text": "Current KT approaches faulter in actually representing knowledge states, often due to a lack of ability to semantically interpret text and concepts. The authors use pre-trained Language Models to give a semantyc meaning to text, making this now possible to use in KT modelling. ",
      "raw": {
        "object": "block",
        "id": "ac46aeab-e180-40ec-a96d-4b6a00f5342e",
        "parent": {
          "type": "page_id",
