    {
      "id": "18e4750c-f3ba-8068-a78b-e25324f82648",
      "type": "paragraph",
      "text": "Authors touch on the concept of Social Capital as a driver that fosters academic performance. They explore how social capital influences performance in first-year undergraduates. Authors use path analysis to evaluate how different forms of social capital influence performance. ",
      "raw": {
        "object": "block",
        "id": "18e4750c-f3ba-8068-a78b-e25324f82648",
        "parent": {
          "type": "page_id",
          "page_id": "18d4750c-f3ba-808a-9b54-cf18a2b15622"
        },
        "created_time": "2025-02-02T23:20:00.000Z",
        "last_edited_time": "2025-03-25T22:07:00.000Z",
