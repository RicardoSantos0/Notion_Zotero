    {
      "id": "18f4750c-f3ba-802c-823f-e75803de9489",
      "type": "paragraph",
      "text": "CFA is an important reearch interest, especially in the context of ITS, generating models such as BKT, PFA and DKT (which uses RNN). The problem with the DKT apporach is that it considers only a subset of features related with the knowledge components of a problem.",
      "raw": {
        "object": "block",
        "id": "18f4750c-f3ba-802c-823f-e75803de9489",
        "parent": {
          "type": "page_id",
          "page_id": "18c4750c-f3ba-80ed-ab50-ddb033db9f04"
        },
        "created_time": "2025-02-03T21:30:00.000Z",
        "last_edited_time": "2025-02-03T21:32:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "CFA is an important reearch interest, especially in the context of ITS, generating models such as BKT, PFA and DKT (which uses RNN). The problem with the DKT apporach is that it considers only a subset of features related with the knowledge components of a problem.",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
