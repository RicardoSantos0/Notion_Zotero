    {
      "id": "18f4750c-f3ba-8030-a3dc-dc8b7e356328",
      "type": "paragraph",
      "text": "In order to work, ITS require good representations of students and their knowledge, with BKT being among the most popular representations. However, BKT does not account for hierarchical relationships between skills, something that Dynamic Bayesian networks (DBN) address. ",
      "raw": {
        "object": "block",
        "id": "18f4750c-f3ba-8030-a3dc-dc8b7e356328",
        "parent": {
          "type": "page_id",
          "page_id": "18b4750c-f3ba-8013-a14e-cc3d2eaf6f7b"
        },
        "created_time": "2025-02-03T18:22:00.000Z",
        "last_edited_time": "2025-02-03T18:27:00.000Z",
        "created_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "last_edited_by": {
          "object": "user",
          "id": "20a7795c-3622-4527-bd13-5ddbf48dc31d"
        },
        "has_children": false,
        "in_trash": false,
        "type": "paragraph",
        "paragraph": {
          "rich_text": [
            {
              "type": "text",
              "text": {
                "content": "In order to work, ITS require good representations of students and their knowledge, with BKT being among the most popular representations. However, BKT does not account for hierarchical relationships between skills, something that Dynamic Bayesian networks (DBN) address. ",
                "link": null
              },
              "annotations": {
                "bold": false,
                "italic": false,
                "strikethrough": false,
