  "annotations": [
    {
      "id": "an_df641634",
      "reference_id": "878bdfe3-953d-4dbf-a65e-7d2ddc46f071",
      "text": "Most AIED techgnologies attempt to improve learning in what the authors describe to be an indirect manner. The authors present a recommender system that aims to maximize student performance directly. Essencially, this system has a pool of exercises and, for a given student, computes the expected score the student would have if the student learns the next exercise. Then, it recommends the exercise that maximizes the score.",
      "provenance": {
        "page_id": "878bdfe3-953d-4dbf-a65e-7d2ddc46f071"
      }
    },
    {
