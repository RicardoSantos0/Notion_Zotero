    {
      "id": "an_abb801c2",
      "reference_id": "59bdd304-77f5-4d11-bb6d-94359984d0bb",
      "text": "The paper starts with a discussion of the potential of Learning Analytics for the early identification of students at risk. However there are important challenges that warrant addressing with Data imbalance being among the most important ones.",
      "provenance": {
        "page_id": "59bdd304-77f5-4d11-bb6d-94359984d0bb"
      }
    },
    {
      "id": "an_b90c7935",
      "reference_id": "59bdd304-77f5-4d11-bb6d-94359984d0bb",
      "text": "The authors collect data from 12 BLearning courses and summarized 3 grading policies. Courses where the grading policy was lenient were more likely to cause the illusion of highly accurate predictive models. Authors also discuss the effectiveness of a lenient grading policy altogether.",
      "provenance": {
        "page_id": "59bdd304-77f5-4d11-bb6d-94359984d0bb"
      }
    }
